/* ── Anti-FOUC ───────────────────────────────────────────
   On refresh the raw Alpine markup paints before Alpine boots and (on Luma)
   before the Tailwind CDN compiles, flashing the unstyled "old" UI. Keep the
   finder hidden until it is genuinely ready — _reveal() adds .ks-ready once
   Alpine has booted AND the first store load finished — and show a pure-CSS
   spinner (no JS / no Tailwind needed) in its place meanwhile. */
.ks-locator:not(.ks-ready){display:none!important;}
#ks-sf-boot{min-height:480px;display:flex;align-items:center;justify-content:center;background:#f9fafb;}
#ks-sf-boot .ks-sf-spin{display:inline-block;width:42px;height:42px;border:4px solid #e5e7eb;border-top-color:#0535F5;border-radius:50%;animation:ks-sf-spin .7s linear infinite;}
