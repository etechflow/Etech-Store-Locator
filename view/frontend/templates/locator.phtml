                        <p style="font-size:11.5px;color:#6B7280;margin:0;line-height:1.5;">Professional help for your vehicle</p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>


<script>
function storeLocator() {
    return {
        allStores:      [],
        filteredStores: [],
        selectedStore:  null,
        mode:           'address',
        addressQuery:   '',
        storeQuery:     '',
        radius:         10,
        sortBy:         'nearest',
        userLat:        null,
        userLng:        null,
        currentPage:    1,
        perPage:        5,
        loading:        true,
        error:          null,
        map:            null,
        markers:        [],

        get totalPages() { return Math.max(1, Math.ceil(this.filteredStores.length / this.perPage)); },
        get pagedStores() { const start = (this.currentPage - 1) * this.perPage; return this.filteredStores.slice(start, start + this.perPage); },

        async init() {
            try {
                const _u = '<?= $searchUrl ?>';
                const res  = await fetch(_u + (_u.indexOf('?') === -1 ? '?' : '&') + '_=' + Date.now(), { cache: 'no-store' });
                const data = await res.json();
                const list = Array.isArray(data) ? data : (data.stores || []);
                this.allStores = list.map(s => ({ ...s, lat: parseFloat(s.lat), lng: parseFloat(s.lng), distance: null }));
                this.filteredStores = [...this.allStores];
            } catch (e) {
                this.error = 'Could not load store data. Please try again later.';
            }
            this.loading = false;
            this._reveal();
            await this.ensureLeaflet();
            this.$nextTick(() => requestAnimationFrame(() => this.initMap()));
        },

        _reveal() {
            // First paint is ready: latch .ks-ready (one-way) to un-hide the finder
            // and drop the boot spinner. Subsequent searches reuse the in-component
            // loading spinner, so this never re-hides the UI.
            if (this.$root) { this.$root.classList.add('ks-ready'); }
            var _b = document.getElementById('ks-sf-boot');
            if (_b) { _b.remove(); }
        },

        ensureLeaflet() {
            return new Promise(resolve => {
                if (typeof L !== 'undefined') return resolve();
                const t = setInterval(() => { if (typeof L !== 'undefined') { clearInterval(t); resolve(); } }, 100);
                setTimeout(() => { clearInterval(t); resolve(); }, 6000);
            });
        },

        initMap() {
            if (typeof L === 'undefined' || this.map || !document.getElementById('ks-store-map')) return;
            const center = this.allStores.length ? [this.allStores[0].lat, this.allStores[0].lng] : [52.6, -1.5];
            this.map = L.map('ks-store-map', { scrollWheelZoom: false }).setView(center, this.allStores.length === 1 ? 13 : 6);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors', maxZoom: 19
            }).addTo(this.map);
            this.renderMarkers();
            // Anti-FOUC reveals the finder from display:none and it lives in a flex column,
            // so on a fast (full-page-cached) load Leaflet can measure a 0-size container
            // (the classic grey box). Re-assert size after layout settles: next paint, a few
            // delays, and whenever the container actually changes size (e.g. on reveal).
            const _fixMap = () => { if (this.map) { this.map.invalidateSize(); this.renderMarkers(); } };
            requestAnimationFrame(() => requestAnimationFrame(_fixMap));
            [120, 400, 900, 1800].forEach(ms => setTimeout(_fixMap, ms));
            const _mapEl = document.getElementById('ks-store-map');
            if (window.ResizeObserver && _mapEl) { new ResizeObserver(_fixMap).observe(_mapEl); }
        },

        renderMarkers() {
            if (!this.map) return;
            this.markers.forEach(m => this.map.removeLayer(m));
            this.markers = [];
            const pts = [];
            this.filteredStores.forEach(store => {
                if (!store.lat || !store.lng) return;
                const marker = L.circleMarker([store.lat, store.lng], {
                    radius: 9, fillColor: '#C41818', fillOpacity: 1, color: '#ffffff', weight: 2
                }).addTo(this.map);
                const address = [store.street, store.city, store.county, store.postcode].filter(Boolean).join(', ');
                marker.bindPopup(
                    '<div style="font-family:Inter,sans-serif;padding:2px;min-width:160px">' +
                    '<p style="font-weight:700;font-size:13px;margin:0 0 4px">' + store.name + '</p>' +
                    '<p style="font-size:11px;color:#6b7280;margin:0 0 6px">' + address + '</p>' +
                    (store.phone ? '<p style="font-size:11px;color:#6b7280;margin:0">' + store.phone + '</p>' : '') +
                    '</div>'
                );
                marker._ksName = store.name;
                marker.on('click', () => this.selectStore(store));
                this.markers.push(marker);
                pts.push([store.lat, store.lng]);
            });
            if (pts.length === 1) { this.map.setView(pts[0], 13); }
            else if (pts.length > 1) { this.map.fitBounds(pts, { padding: [40, 40] }); }
        },

        selectStore(store) {
            this.selectedStore = store;
            if (!this.map || !store.lat || !store.lng) return;
            this.map.setView([store.lat, store.lng], 15);
            const mk = this.markers.find(m => m._ksName === store.name);
            if (mk) mk.openPopup();
        },

        async searchByAddress() {
            const q = this.addressQuery.trim();
            if (!q) return;
            this.loading = true; this.error = null;
            let lat = null, lng = null;
            try {
                let r = await fetch('https://api.postcodes.io/postcodes/' + encodeURIComponent(q));
                let j = await r.json();
                if (j.status === 200 && j.result) { lat = j.result.latitude; lng = j.result.longitude; }
                if (lat === null) {
                    r = await fetch('https://api.postcodes.io/outcodes/' + encodeURIComponent(q.replace(/\s+/g, '')));
                    j = await r.json();
                    if (j.status === 200 && j.result) { lat = j.result.latitude; lng = j.result.longitude; }
                }
                if (lat === null) {
                    r = await fetch('https://api.postcodes.io/postcodes?q=' + encodeURIComponent(q) + '&limit=1');
                    j = await r.json();
                    if (j.result && j.result.length) { lat = j.result[0].latitude; lng = j.result[0].longitude; }
                }
                if (lat === null) {
                    // Free-text fallback (town / street / full address) via OSM Nominatim, UK-biased.
                    r = await fetch('https://nominatim.openstreetmap.org/search?format=json&countrycodes=gb&limit=1&q=' + encodeURIComponent(q));
                    j = await r.json();
                    if (Array.isArray(j) && j.length) { lat = parseFloat(j[0].lat); lng = parseFloat(j[0].lon); }
                }
            } catch (e) {}
            this.loading = false;
            if (lat === null) { this.error = 'Address not found. Please try a UK postcode or town.'; return; }
            this.error = null;
            this.userLat = lat; this.userLng = lng;
            this.filteredStores = this.allStores
                .map(s => ({ ...s, distance: (s.lat && s.lng) ? this.haversine(lat, lng, s.lat, s.lng) : null }))
                .filter(s => s.distance !== null && s.distance <= this.radius)
                .sort((a, b) => a.distance - b.distance);
            this.currentPage = 1;
            this.$nextTick(() => this.renderMarkers());
        },

        filterStores() {
            const q = this.storeQuery.trim().toLowerCase();
            this.filteredStores = q
                ? this.allStores.filter(s =>
                    s.name.toLowerCase().includes(q) ||
                    (s.city && s.city.toLowerCase().includes(q)) ||
                    (s.postcode && s.postcode.toLowerCase().includes(q))
                  )
                : [...this.allStores];
            this.currentPage = 1;
            this.$nextTick(() => this.renderMarkers());
        },

        sortStores() {
            if (this.sortBy === 'name') {
                this.filteredStores = [...this.filteredStores].sort((a, b) => a.name.localeCompare(b.name));
            } else if (this.sortBy === 'nearest' && this.userLat !== null) {
                this.filteredStores = [...this.filteredStores].sort((a, b) => (a.distance ?? 999) - (b.distance ?? 999));
            }
        },

        resetSearch() {
            this.addressQuery   = '';
            this.storeQuery     = '';
            this.userLat        = null;
            this.userLng        = null;
            this.error          = null;
            this.radius         = 10;
            this.filteredStores = this.allStores.map(s => ({ ...s, distance: null }));
            this.currentPage    = 1;
            this.selectedStore  = null;
            this.$nextTick(() => this.renderMarkers());
        },

        openStreetView(store) {
            if (!store.lat || !store.lng) return;
            window.open('https://www.google.com/maps/@?api=1&map_action=pano&viewpoint=' + store.lat + ',' + store.lng, '_blank');
        },

        haversine(lat1, lng1, lat2, lng2) {
            const R = 3958.8; // miles
            const dLat = (lat2 - lat1) * Math.PI / 180;
            const dLng = (lng2 - lng1) * Math.PI / 180;
            const a = Math.sin(dLat/2)**2 +
                      Math.cos(lat1*Math.PI/180) * Math.cos(lat2*Math.PI/180) * Math.sin(dLng/2)**2;
            return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
        },
    };
}
</script>

