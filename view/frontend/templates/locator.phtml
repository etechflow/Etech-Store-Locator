<?php /* Theme-agnostic boot. Hyvä already ships Tailwind + Alpine; on Luma (or any
       non-Tailwind theme) load them on THIS page only, so the store finder is styled
       and interactive on either theme. Preflight is disabled so Tailwind's global CSS
       reset never touches the surrounding Luma header/footer. */ ?>
<script>
(function () {
    // Probe: does the active theme already provide Tailwind? (Hyvä does — '.flex' resolves.)
    var probe = document.createElement('div');
    probe.className = 'flex';
    document.body.appendChild(probe);
    var hasTailwind = window.getComputedStyle(probe).display === 'flex';
    document.body.removeChild(probe);
    if (hasTailwind) { return; }   // Hyvä — nothing to do.

    // Luma fallback — register the brand colours the markup uses, disable preflight,
    // then pull in Tailwind (JIT) and Alpine for this page.
    window.tailwind = {
        config: {
            corePlugins: { preflight: false },
            theme: { extend: { colors: { brand: {
                dark: '#0E1025', blue: '#0535F5', red: '#C41818'
            } } } }
        }
    };
    var tw = document.createElement('script');
    tw.src = 'https://cdn.tailwindcss.com';
    document.head.appendChild(tw);

    if (typeof window.Alpine === 'undefined') {
        var al = document.createElement('script');
        al.src = 'https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js';
        al.defer = true;
        document.head.appendChild(al);
    }
})();
</script>

<?php /* Boot loader: a pure-CSS spinner shown in the finder's place until Alpine
       has booted AND the first store load has finished (see _reveal()), so the
       unstyled markup never flashes on refresh. The timeout below is a safety net
       so a hung network can never leave the page spinning forever. */ ?>
<div id="ks-sf-boot" role="status" aria-live="polite" aria-busy="true" aria-label="<?= $escaper->escapeHtmlAttr(__('Loading store finder')) ?>">
    <span class="ks-sf-spin"></span>
</div>
