<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="etechflow_store_locator" resource="default" engine="innodb" comment="Etechflow Store Locator">
        <column xsi:type="int" name="store_id" unsigned="true" nullable="false" identity="true" comment="Store ID"/>
        <column xsi:type="varchar" name="name" nullable="false" length="255" comment="Store Name"/>
        <column xsi:type="varchar" name="street" nullable="true" length="255" comment="Street Address"/>
        <column xsi:type="varchar" name="city" nullable="true" length="255" comment="City"/>
        <column xsi:type="varchar" name="county" nullable="true" length="255" comment="County"/>
        <column xsi:type="varchar" name="postcode" nullable="true" length="20" comment="Postcode"/>
        <column xsi:type="varchar" name="phone" nullable="true" length="50" comment="Phone Number"/>
        <column xsi:type="decimal" name="lat" nullable="true" scale="7" precision="10" comment="Latitude"/>
        <column xsi:type="decimal" name="lng" nullable="true" scale="7" precision="10" comment="Longitude"/>
        <column xsi:type="varchar" name="image" nullable="true" length="255" comment="Store Image"/>
        <column xsi:type="varchar" name="store_url" nullable="true" length="255" comment="Store URL"/>
        <column xsi:type="smallint" name="is_active" nullable="false" default="1" unsigned="true" comment="Is Active"/>
        <column xsi:type="int" name="sort_order" nullable="false" default="0" comment="Sort Order"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="store_id"/>
        </constraint>
        <index referenceId="ETECHFLOW_STORE_LOCATOR_IS_ACTIVE" indexType="btree">
            <column name="is_active"/>
        </index>
        <index referenceId="ETECHFLOW_STORE_LOCATOR_SORT_ORDER" indexType="btree">
            <column name="sort_order"/>
        </index>
    </table>
</schema>
