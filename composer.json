{
    "name": "etechflow/module-store-locator",
    "description": "EtechFlow Store Locator — admin-managed store/branch finder for Magento 2 with a Leaflet + OpenStreetMap map and postcode proximity search (postcodes.io). Hyva and Luma compatible. No paid map API key required.",
    "type": "magento2-module",
    "version": "1.1.2",
    "license": "proprietary",
    "homepage": "https://etechflow.com/products/store-locator",
    "support": {
        "email": "support@etechflow.com",
        "source": "https://github.com/etechflow/Etech-Store-Locator"
    },
    "keywords": ["magento","magento2","store-locator","store-finder","map","leaflet","openstreetmap","hyva","etechflow"],
    "require": {
        "php": ">=8.1",
        "magento/framework": ">=103.0",
        "magento/module-backend": ">=102.0",
        "magento/module-config": ">=101.0",
        "magento/module-catalog": ">=104.0"
    },
    "autoload": {
        "files": ["registration.php"],
        "psr-4": { "Etechflow\\StoreLocator\\": "" }
    }
}
